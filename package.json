{
  "name": "capillaris",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "dev:api": "turbo dev --filter=@capillaris/api",
    "dev:web": "turbo dev --filter=@capillaris/web",
    "build:api": "turbo build --filter=@capillaris/api",
    "build:web": "turbo build --filter=@capillaris/web"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20"
  }
}
