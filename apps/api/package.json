{
  "name": "@capillaris/api",
  "version": "0.0.1",
  "private": true,
  "description": "Capillaris API - NestJS Backend",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "nest start --watch",
    "dev:prod": "dotenv -e .env.production -e .env -- nest start --watch",
    "build": "nest build",
    "start": "node dist/src/main",
    "start:prod": "node dist/src/main",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:deploy:dev": "dotenv -e .env -- prisma migrate deploy",
    "prisma:deploy:prod": "dotenv -e .env.production -- prisma migrate deploy",
    "prisma:studio:prod": "dotenv -e .env.production -- prisma studio"
  },
  "dependencies": {
    "@capillaris/shared": "*",
    "@nestjs/common": "^10.4",
    "@nestjs/config": "^3.2",
    "@nestjs/core": "^10.4",
    "@nestjs/jwt": "^10.2",
    "@nestjs/passport": "^10.0",
    "@nestjs/platform-express": "^10.4",
    "@nestjs/swagger": "^7.4",
    "@prisma/client": "^5.19",
    "bcrypt": "^5.1",
    "class-transformer": "^0.5",
    "class-validator": "^0.14",
    "googleapis": "^171.4.0",
    "nodemailer": "^8.0.2",
    "passport": "^0.7",
    "passport-jwt": "^4.0",
    "passport-local": "^1.0",
    "reflect-metadata": "^0.2",
    "rxjs": "^7.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4",
    "@nestjs/schematics": "^10.1",
    "@nestjs/testing": "^10.4",
    "@types/bcrypt": "^5.0",
    "@types/express": "^4.17",
    "@types/jest": "^29.5",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/passport-jwt": "^4.0",
    "@types/passport-local": "^1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.57",
    "jest": "^29.7",
    "prisma": "^5.19",
    "source-map-support": "^0.5",
    "ts-jest": "^29.2",
    "ts-node": "^10.9",
    "typescript": "^5.4"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
