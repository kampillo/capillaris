# Database
DATABASE_URL="postgresql://user:password@localhost:5432/capillaris?schema=public"

# JWT
JWT_SECRET="change-me-in-production"
JWT_EXPIRATION="24h"

# Storage (Cloudflare R2 - S3 compatible)
S3_ENDPOINT="https://your-account.r2.cloudflarestorage.com"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET="capillaris-images"
S3_REGION="auto"

# Google Calendar OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3001/api/v1/google/callback"

# App
PORT=3001
NODE_ENV=development
