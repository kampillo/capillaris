# MySQL Source (Legacy Laravel DB - dockerized via docker-compose.yml)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=root
MYSQL_PASSWORD=migration
MYSQL_DATABASE=capillaris_legacy

# PostgreSQL Target (Prisma)
# Override in .env.migration.local with your real Neon/Postgres URL
DATABASE_URL=postgresql://kampiyo@127.0.0.1:5432/capillaris?schema=public

# Migration settings
MIGRATION_NAMESPACE=capillaris-migration
CURRENT_YEAR=2026
