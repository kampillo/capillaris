  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": false,
    "paths": {
      "@prisma/client": ["../../apps/api/node_modules/@prisma/client"]
    }
  },
  "include": ["src/**/*.ts"]
